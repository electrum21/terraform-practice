# Example terraform.tfvars file
# Copy this file to terraform.tfvars and update with your values

primary_region   = "us-east-1"
secondary_region = "us-west-2"

primary_vpc_cidr   = "10.0.0.0/16"
secondary_vpc_cidr = "10.1.0.0/16"

primary_subnet_cidr   = "10.0.1.0/24"
secondary_subnet_cidr = "10.1.1.0/24"

instance_type = "t2.micro"

# IMPORTANT: Create an EC2 key pair in both regions before running this demo
# Use different key names for clarity
# To do so, run command:
# aws ec2 create-key-pair --key-name vpc-peering-demo --region <region> --query 'KeyMaterial' --output text > <vpc-peering-demo>-<east/west>.pem  
# Note: The key name with east/west is the file name, but the key saved in EC2 instance is named vpc-peering-demo   
primary_key_name   = "vpc-peering-demo"
secondary_key_name = "vpc-peering-demo"
